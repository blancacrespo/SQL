SELECT * FROM INSCRITOS;

-- PREGUNTA 1: ¿Cuantos registros hay?
SELECT COUNT(*) AS total_registros
FROM INSCRITOS;

-- PREGUNTA 2: ¿Cuantos inscritos hay en total?
SELECT SUM(cantidad) AS total_inscritos
FROM INSCRITOS;

-- PREGUNTA 3: ¿Cual o cuales son los registros de mayor antiguedad?
SELECT *
FROM INSCRITOS
WHERE fecha = (
    SELECT MIN(fecha)
    FROM INSCRITOS
);

-- PREGUNTA 4: ¿Cuantos inscritos hay por dia? (Indistintamente de la fuente de inscripcion)
SELECT fecha, SUM(cantidad) AS inscritos_por_dia
FROM INSCRITOS
GROUP BY fecha
ORDER BY fecha;

-- PREGUNTA 5: ¿Cuantos inscritos hay por fuente?
SELECT fuente, SUM(cantidad) AS inscritos_por_fuente
FROM INSCRITOS
GROUP BY fuente
ORDER BY fuente;

-- PREGUNTA 6: ¿Que dia se inscribio la mayor cantidad de personas? y ¿Cuántas personas se inscribieron en ese dia?
SELECT fecha, SUM(cantidad) AS total_inscritos
FROM INSCRITOS
GROUP BY fecha
ORDER BY total_inscritos DESC
LIMIT 1;

-- PREGUNTA 7: ¿Que dia se inscribieron la mayor cantidad de personas utilizando el blog? ¿Cuantas personas fueron? (si hay mas de un registro con el maximo de personas, considera solo el primero)
SELECT fecha, cantidad
FROM INSCRITOS
WHERE fuente = 'Blog'
ORDER BY cantidad DESC, fecha ASC
LIMIT 1;

-- PREGUNTA 8: ¿Cual es el promedio de personas inscritas por dia? Toma en consideracion que la base de datos tiene un registro de 8 dias, es decir, se obtendran 8 promedios.
SELECT fecha, ROUND(AVG(cantidad), 2) AS promedio_por_dia
FROM INSCRITOS
GROUP BY fecha
ORDER BY fecha;

-- PREGUNTA 9: ¿Que dias se inscribieron mas de 50 personas?
SELECT fecha, SUM(cantidad) AS total_inscritos
FROM INSCRITOS
GROUP BY fecha
HAVING SUM(cantidad) > 50
ORDER BY fecha;

-- PREGUNTA 10: ¿Cual es el promedio por día de personas inscritas? Considerando solo calcular desde el tercer dia.
SELECT fecha, ROUND(AVG(cantidad), 2) AS promedio_diario
FROM INSCRITOS
WHERE fecha >= '2021-01-03'
GROUP BY fecha
ORDER BY fecha;
