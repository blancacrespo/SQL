-- 3. CONSULTAS AVANZADAS CON SELECT
-- ============================================================

-- Consulta 1:
-- Obtener nombre completo, direccion y correo electronico de clientes
-- que han realizado pedidos en los ultimos 30 dias.

SELECT DISTINCT
    CONCAT(c.nombre, ' ', c.apellido) AS nombre_completo,
    c.direccion,
    c.correo_electronico
FROM clientes c
INNER JOIN pedidos p ON c.id_cliente = p.id_cliente
WHERE p.fecha >= CURDATE() - INTERVAL 30 DAY;

-- Consulta 2:
-- Mostrar los productos con mayor cantidad de ventas en el ultimo mes,
-- junto con el total vendido de cada uno.

SELECT
    pr.id_producto,
    pr.nombre AS producto,
    SUM(v.cantidad) AS total_unidades_vendidas
FROM productos pr
INNER JOIN ventas v ON pr.id_producto = v.id_producto
INNER JOIN pedidos p ON v.id_pedido = p.id_pedido
WHERE p.fecha >= CURDATE() - INTERVAL 1 MONTH
GROUP BY pr.id_producto, pr.nombre
ORDER BY total_unidades_vendidas DESC;

-- Consulta 3:
-- Listar los clientes que han realizado mas pedidos en el ultimo año,
-- ordenados por mayor cantidad de pedidos.

SELECT
    c.id_cliente,
    CONCAT(c.nombre, ' ', c.apellido) AS nombre_completo,
    COUNT(p.id_pedido) AS cantidad_pedidos
FROM clientes c
INNER JOIN pedidos p ON c.id_cliente = p.id_cliente
