-- 4. ACTUALIZACION CON UPDATE
-- ============================================================

-- Actualizacion 1:
-- Aumentar el precio de todos los productos de la categoria "Camisetas" en 10%.

UPDATE productos
SET precio = precio * 1.10
WHERE categoria = 'Camisetas';

-- Verificacion del UPDATE
SELECT id_producto, nombre, categoria, precio
FROM productos
WHERE categoria = 'Camisetas';

-- ============================================================
-- 5. ELIMINACION CON DELETE
-- ============================================================

-- Eliminacion 2:
-- Eliminar los pedidos que no tengan ventas asociadas.

DELETE FROM pedidos
WHERE id_pedido NOT IN (
    SELECT id_pedido
    FROM ventas
);

-- Verificacion del DELETE
SELECT p.id_pedido, p.fecha, p.estado, p.total
FROM pedidos p
LEFT JOIN ventas v ON p.id_pedido = v.id_pedido
WHERE v.id_venta IS NULL;

-- ============================================================
-- 6. CREACION DE VISTAS
-- ============================================================

-- Vista 1:
-- Crear una vista llamada vista_clientes_pedidos que muestre
-- nombre completo del cliente, fecha del pedido y total del pedido.

CREATE OR REPLACE VIEW vista_clientes_pedidos AS
SELECT
    CONCAT(c.nombre, ' ', c.apellido) AS nombre_completo,
    p.fecha AS fecha_pedido,
    p.total AS total_pedido
FROM clientes c
INNER JOIN pedidos p ON c.id_cliente = p.id_cliente;

-- Consulta para visualizar la vista creada
SELECT *
FROM vista_clientes_pedidos;
