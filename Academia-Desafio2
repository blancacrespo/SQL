CREATE TABLE usuarios(
    id SERIAL PRIMARY KEY,
    email VARCHAR(255),
    nombre VARCHAR(100),
    apellido VARCHAR(100),
    rol VARCHAR(50)
);

CREATE TABLE posts(
    id SERIAL PRIMARY KEY,
    titulo VARCHAR(255),
    contenido TEXT,
    fecha_creacion TIMESTAMP,
    fecha_actualizacion TIMESTAMP,
    destacado BOOLEAN,
    usuario_id BIGINT,
    FOREIGN KEY (usuario_id) REFERENCES usuarios(id)
);

-- Pregunta 1: Crea y agrega al entregable las consultas para completar el setup de acuerdo a lo pedido
CREATE TABLE comentarios(
    id SERIAL PRIMARY KEY,
    contenido TEXT,
    fecha_creacion TIMESTAMP,
    usuario_id BIGINT,
    post_id BIGINT,
    FOREIGN KEY (usuario_id) REFERENCES usuarios(id),
    FOREIGN KEY (post_id) REFERENCES posts(id)
);

